# ─────────────────────────────────────────────────────────────────────────────
# Socratic Math Tutor — Environment Variables
# Copy this file to `.env` and fill in your values.
#
# Quick Start:
#   macOS / Linux:
#     cp .env.example .env
#   Windows PowerShell:
#     copy .env.example .env
#
# ⚠️  SECURITY WARNING:
#   Never commit your actual `.env` file to Git. It contains secrets.
#   The `.env.example` file is safe to commit as it only has placeholders.
# ─────────────────────────────────────────────────────────────────────────────

# GEMINI_API_KEY
# Required. Your Google Gemini API key used to power the AI tutor.
# Obtain one at: https://aistudio.google.com/app/apikey
#
# In production (AI Studio / Cloud Run), this is injected automatically
# via the Secrets panel. Do not hardcode secrets in your source code.
GEMINI_API_KEY=your_gemini_api_key_here

# APP_URL
# Optional. The public URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
#
# In production (AI Studio / Cloud Run), this is injected automatically
# with the Cloud Run service URL.
# Leave blank for local development.
APP_URL=
