# ─────────────────────────────────────────────────────────────────────────────
# Socratic Math Tutor — Environment Variables
# Copy this file to `.env` and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# GEMINI_API_KEY
# Required. Your Google Gemini API key used to power the AI tutor.
# Obtain one at: https://aistudio.google.com/app/apikey
# In AI Studio, this is injected automatically via the Secrets panel.
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL
# Optional. The public URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
# In AI Studio, this is injected automatically with the Cloud Run service URL.
# Leave blank for local development.
APP_URL=""
